LLM_PROVIDER=databricks
LLM_API_KEY=
LLM_BASE_URL=https://dbc-c760812f-3e1e.cloud.databricks.com/serving-endpoints
LLM_MODEL=databricks-meta-llama-3-3-70b-instruct
LLM_RESPONSE_FORMAT=
LLM_TIMEOUT_SECONDS=180

# Leave empty to reuse LLM_API_KEY when using the same Databricks endpoint root.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dbc-c760812f-3e1e.cloud.databricks.com/serving-endpoints
EMBEDDING_MODEL=databricks-qwen3-embedding-0-6b
EMBEDDING_BATCH_SIZE=10

RERANK_PROVIDER=aws_bedrock
RERANK_MODEL=cohere.rerank-v3-5:0
RERANK_TOP_N=8
RERANK_AWS_REGION=us-east-1

OCR_PROVIDER=aws_textract
OCR_MODEL=aws-textract-detect-document-text
OCR_AWS_REGION=us-east-1
OCR_TIMEOUT_SECONDS=120
OCR_MIN_TEXT_CHARS=80
OCR_RENDER_DPI=144

# Optional Databricks vision OCR fallback. AWS Textract remains the default.
# OCR_PROVIDER=databricks_vision
# OCR_API_KEY=
# OCR_BASE_URL=https://dbc-c760812f-3e1e.cloud.databricks.com/serving-endpoints
# OCR_MODEL=databricks-llama-4-maverick

# Put real credentials only in local .env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

MULTILINGUAL_QUERY_TERMS_ENABLED=true
MULTILINGUAL_QUERY_TERM_WEIGHT=0.45
KEYWORD_BM25_K1=1.4
KEYWORD_BM25_B=0.75

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
