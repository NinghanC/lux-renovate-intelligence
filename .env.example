LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-flash
# Leave empty for DashScope-compatible mode. Set to json_object only for providers that support OpenAI JSON mode.
LLM_RESPONSE_FORMAT=
LLM_TIMEOUT_SECONDS=180

EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BATCH_SIZE=10

RERANK_API_KEY=
RERANK_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_MODEL=qwen3-rerank
RERANK_TOP_N=8

OCR_API_KEY=
OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_MODEL=qwen-vl-ocr-latest
OCR_TIMEOUT_SECONDS=120
OCR_MIN_TEXT_CHARS=80
OCR_RENDER_DPI=144

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
