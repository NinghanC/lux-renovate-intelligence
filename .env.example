API_AUTH_ENABLED=true
API_AUTH_TOKEN=dev-demo-token-change-me

LLM_PROVIDER=mock
LLM_MOCK_MODE=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_RESPONSE_FORMAT=
LLM_TIMEOUT_SECONDS=180
EXTERNAL_API_MAX_ATTEMPTS=3
EXTERNAL_API_RETRY_DELAY_SECONDS=0.25
UPLOAD_MAX_BYTES=10485760

# Optional second LLM used only for report-only semantic quality review.
# Leave disabled for the public demo.
SEMANTIC_REVIEW_PROVIDER=disabled
SEMANTIC_REVIEW_API_KEY=
SEMANTIC_REVIEW_BASE_URL=
SEMANTIC_REVIEW_MODEL=
SEMANTIC_REVIEW_RESPONSE_FORMAT=json_object
SEMANTIC_REVIEW_TIMEOUT_SECONDS=120

# Optional embedding endpoint. Leave empty for keyword-only retrieval.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_BATCH_SIZE=10

RERANK_PROVIDER=disabled
RERANK_MODEL=
RERANK_TOP_N=8
RERANK_AWS_REGION=

OCR_PROVIDER=disabled
OCR_MODEL=
OCR_AWS_REGION=
OCR_TIMEOUT_SECONDS=120
OCR_MIN_TEXT_CHARS=80
OCR_RENDER_DPI=144

# Optional real LLM example. Put actual values only in local .env, never in commits.
# LLM_PROVIDER=openai_compatible
# LLM_MOCK_MODE=false
# LLM_API_KEY=<your-llm-token>
# LLM_BASE_URL=https://<your-provider-host>/<openai-compatible-path>
# LLM_MODEL=<your-chat-model-or-serving-endpoint-name>

# Optional semantic reviewer example. Keep disabled unless you want a second LLM quality-control pass.
# SEMANTIC_REVIEW_PROVIDER=openai_compatible
# SEMANTIC_REVIEW_API_KEY=<your-review-token>
# SEMANTIC_REVIEW_BASE_URL=https://<your-provider-host>/<openai-compatible-path>
# SEMANTIC_REVIEW_MODEL=<your-review-model-or-serving-endpoint-name>

# Optional cloud rerank/OCR examples. Keep disabled for the public demo.
# RERANK_PROVIDER=<your-rerank-provider>
# RERANK_MODEL=<your-rerank-model-id-or-arn>
# RERANK_AWS_REGION=<your-region-if-applicable>
# OCR_PROVIDER=<your-ocr-provider>
# OCR_MODEL=<your-ocr-provider-label>
# OCR_AWS_REGION=<your-region-if-applicable>

# Put real credentials only in local .env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

MULTILINGUAL_QUERY_TERMS_ENABLED=true
MULTILINGUAL_QUERY_TERM_WEIGHT=0.45
KEYWORD_BM25_K1=1.4
KEYWORD_BM25_B=0.75

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false
CORS_METHODS=GET,POST
CORS_HEADERS=Content-Type,X-API-Key
